<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Surface Tokens -->
    <SolidColorBrush x:Key="AppSurface" Color="#1A1714"/>
    <SolidColorBrush x:Key="ChromeSurface" Color="#211E1B"/>
    <SolidColorBrush x:Key="PanelSurface" Color="#242018"/>
    <SolidColorBrush x:Key="ActivePanelSurface" Color="#1A2535"/>
    <SolidColorBrush x:Key="RosterPanelSurface" Color="#252018"/>
    <SolidColorBrush x:Key="SidebarPanelSurface" Color="#1F1C16"/>
    <SolidColorBrush x:Key="SidebarPanelBorder" Color="#3C3529"/>
    <SolidColorBrush x:Key="WorkspaceSurface" Color="#222018"/>
    <SolidColorBrush x:Key="CardSurface" Color="#2E2920"/>
    <SolidColorBrush x:Key="HoverSurface" Color="#252220"/>
    <SolidColorBrush x:Key="TranscriptLinkHoverSurface" Color="#252220"/>
    <SolidColorBrush x:Key="ApprovalSelectedSurface" Color="#80252220"/>
    <SolidColorBrush x:Key="TranscriptSurface" Color="#1E1C17"/>
    <SolidColorBrush x:Key="TextBoxBackground" Color="#131110"/>
    <SolidColorBrush x:Key="InputSurface" Color="#242018"/>
    <SolidColorBrush x:Key="FollowUpSurface" Color="#12100C"/>
    <SolidColorBrush x:Key="QueueCardSurface" Color="#1E1B18"/>
    <SolidColorBrush x:Key="QueueCardEditingSurface" Color="#0D1A28"/>
    <SolidColorBrush x:Key="QueueTabActiveBorder"    Color="#42A5F5"/>
    <SolidColorBrush x:Key="QueueTabInactiveText"    Color="#AF987F"/>
    <SolidColorBrush x:Key="TaskPriorityHigh"        Color="#FF5252"/>
    <SolidColorBrush x:Key="TaskPriorityMid"         Color="#FFD740"/>
    <SolidColorBrush x:Key="TaskPriorityLow"         Color="#64B5F6"/>
    <SolidColorBrush x:Key="AlertSurface" Color="#2A2010"/>
    <SolidColorBrush x:Key="RoleBadgeSurface" Color="#3A2E1C"/>
    <SolidColorBrush x:Key="ThreadBadgeSurface" Color="#3A2E1C"/>
    <SolidColorBrush x:Key="PopupSurface" Color="#2A2520"/>
    <SolidColorBrush x:Key="ToastSurface" Color="#2A2010"/>
    <SolidColorBrush x:Key="ChipSurface" Color="#242C38"/>
    <SolidColorBrush x:Key="CodeSurface" Color="#252018"/>
    <SolidColorBrush x:Key="QuoteSurface" Color="#272218"/>
    <SolidColorBrush x:Key="TrackSurface" Color="#3A342C"/>
    <!-- Window Chrome Tokens -->
    <SolidColorBrush x:Key="WindowBorder" Color="#3A342C"/>
    <SolidColorBrush x:Key="CaptionButtonHover" Color="#3A3530"/>
    <SolidColorBrush x:Key="CaptionCloseHover" Color="#B02415"/>
    <SolidColorBrush x:Key="CaptionCloseHoverText" Color="#FFFFFF"/>
    <!-- Danger Button Tokens (Close Now / destructive actions) -->
    <SolidColorBrush x:Key="DangerButtonBg"      Color="#7B1010"/>
    <SolidColorBrush x:Key="DangerButtonHover"   Color="#E53935"/>
    <SolidColorBrush x:Key="DangerButtonPressed" Color="#EF5350"/>
    <SolidColorBrush x:Key="DangerButtonFg"      Color="#FFFFFF"/>
    <!-- Border / Line Tokens -->
    <SolidColorBrush x:Key="PanelBorder" Color="#3A342C"/>
    <SolidColorBrush x:Key="ActivePanelBorder" Color="#2B4065"/>
    <SolidColorBrush x:Key="RosterPanelBorder" Color="#3E3630"/>
    <SolidColorBrush x:Key="WorkspaceBorder" Color="#38322A"/>
    <SolidColorBrush x:Key="LineColor" Color="#3E3730"/>
    <SolidColorBrush x:Key="TranscriptBorder" Color="#38322A"/>
    <SolidColorBrush x:Key="InputBorder" Color="#3A342C"/>
    <SolidColorBrush x:Key="SubtleBorder" Color="#3E3630"/>
    <SolidColorBrush x:Key="CheckBoxBorder" Color="#746858"/><!-- ~2× InputBorder for dark-theme contrast -->
    <SolidColorBrush x:Key="AlertBorder" Color="#5A4820"/>
    <SolidColorBrush x:Key="BadgeBorder" Color="#5A4830"/>
    <SolidColorBrush x:Key="HireAgentImageBorder" Color="#3A342C"/>
    <SolidColorBrush x:Key="ThreadBadgeBorder" Color="#52422C"/>
    <SolidColorBrush x:Key="PopupBorder" Color="#4A4440"/>
    <SolidColorBrush x:Key="ToastBorder" Color="#5A4A20"/>
    <SolidColorBrush x:Key="ChipBorder" Color="#3A5080"/>
    <SolidColorBrush x:Key="QuoteBorder" Color="#6A5038"/>
    <SolidColorBrush x:Key="AvatarImageBorder" Color="#5A5A5A"/>
    <SolidColorBrush x:Key="TableRule" Color="#3A3530"/>
    <SolidColorBrush x:Key="TableHeaderSurface" Color="#2A2520"/>
    <!-- Text Tokens -->
    <SolidColorBrush x:Key="ImportantText" Color="#E5D5C0"/>
    <SolidColorBrush x:Key="LabelText" Color="#D8C8B0"/>
    <SolidColorBrush x:Key="BodyText" Color="#9A8878"/>
    <SolidColorBrush x:Key="CodeText" Color="#D8CCBA"/>
    <SolidColorBrush x:Key="SubtleText" Color="#7A6A58"/>
    <SolidColorBrush x:Key="AgentRoleText" Color="#D4B880"/>
    <SolidColorBrush x:Key="AgentStatusText" Color="#CCA070"/>
    <SolidColorBrush x:Key="AgentDetailText" Color="#8A7868"/>
    <SolidColorBrush x:Key="ActivePanelTitle" Color="#8AB0D0"/>
    <SolidColorBrush x:Key="ActivePanelSubtitle" Color="#5A8098"/>
    <SolidColorBrush x:Key="RosterPanelTitle" Color="#C0A080"/>
    <SolidColorBrush x:Key="ActionLinkText" Color="#6890C8"/>
    <SolidColorBrush x:Key="AlertBodyText" Color="#C08860"/>
    <SolidColorBrush x:Key="ThreadBadgeText" Color="#C8A870"/>
    <SolidColorBrush x:Key="ToastText" Color="#C09840"/>
    <SolidColorBrush x:Key="ChipText" Color="#6BAED6"/>
    <!-- Document Part Tokens -->
    <SolidColorBrush x:Key="TurnDividerText" Color="#C8845A"/>
    <SolidColorBrush x:Key="AgentTaskStartText" Color="#E0A030"/>
    <SolidColorBrush x:Key="UserPromptText" Color="#9090D0"/>
    <SolidColorBrush x:Key="UserPromptPrefixText" Color="#7878A8"/>
    <SolidColorBrush x:Key="VoiceAnnotationText" Color="#606080"/>
    <SolidColorBrush x:Key="SystemErrorText" Color="#FF7070"/>
    <SolidColorBrush x:Key="AbortButtonText"  Color="#FF9898"/>
    <SolidColorBrush x:Key="SystemInfoText" Color="#E0A030"/>
    <SolidColorBrush x:Key="TaskSuccessText" Color="#4EC84E"/>
    <SolidColorBrush x:Key="TaskFailureText" Color="#FF6B6B"/>
    <SolidColorBrush x:Key="DocumentLinkText" Color="#6BAED6"/>
    <SolidColorBrush x:Key="ListMarkerText" Color="#8090A0"/>
    <SolidColorBrush x:Key="BlockquoteBodyText" Color="#8090A0"/>
    <SolidColorBrush x:Key="TableCellText" Color="#A8C0C0"/>
    <SolidColorBrush x:Key="ThinkingText" Color="#E0A840"/>
    <SolidColorBrush x:Key="ThinkingMetaText" Color="#E0A840" Opacity="0.55"/>
    <SolidColorBrush x:Key="KeyboardHintText" Color="#707070"/>
    <SolidColorBrush x:Key="AgentIconTextColor" Color="#1A1A1A"/>
    <!-- Tool Entry Tokens -->
    <SolidColorBrush x:Key="ToolRunningIcon" Color="#6BAED6"/>
    <SolidColorBrush x:Key="ToolSuccessIcon" Color="#4EC84E"/>
    <SolidColorBrush x:Key="ToolFailureIcon" Color="#FF6B6B"/>
    <SolidColorBrush x:Key="ToolBodyText" Color="#A8C0C0"/>
    <SolidColorBrush x:Key="ToolFailureText" Color="#FF6B6B"/>
    <SolidColorBrush x:Key="ToolActionLink" Color="#6BAED6"/>
    <SolidColorBrush x:Key="ToolActionLinkBorder" Color="#3A5070"/>
    <!-- Transcript Action Button Tokens (agent launch chip / report button) -->
    <SolidColorBrush x:Key="TranscriptActionSurface" Color="#1A2535"/>
    <SolidColorBrush x:Key="TranscriptActionHoverSurface" Color="#253550"/>
    <SolidColorBrush x:Key="TranscriptActionBorder" Color="#3A5070"/>
    <SolidColorBrush x:Key="TranscriptActionText" Color="#6BAED6"/>
    <SolidColorBrush x:Key="DiffAddedText" Color="#6BAED6"/>
    <SolidColorBrush x:Key="DiffRemovedText" Color="#E07070"/>
    <SolidColorBrush x:Key="DiffDeletedFileText" Color="#C09090"/>
    <!-- Chip State Tokens -->
    <SolidColorBrush x:Key="ChipSelectedSurface" Color="#1A2F4F"/>
    <SolidColorBrush x:Key="ChipSelectedBorder" Color="#4A70B8"/>
    <SolidColorBrush x:Key="ChipSelectedText" Color="#9AB8E8"/>
    <SolidColorBrush x:Key="ChipCompletedSurface" Color="#1A3020"/>
    <SolidColorBrush x:Key="ChipCompletedBorder" Color="#3A7848"/>
    <SolidColorBrush x:Key="ChipCompletedText" Color="#5AC87A"/>
    <SolidColorBrush x:Key="ChipFailedSurface" Color="#301818"/>
    <SolidColorBrush x:Key="ChipFailedBorder" Color="#885050"/>
    <SolidColorBrush x:Key="ChipFailedText" Color="#E07070"/>
    <!-- Quick Reply Tokens -->
    <SolidColorBrush x:Key="QuickReplySurface" Color="#1A2535"/>
    <SolidColorBrush x:Key="QuickReplyBorder" Color="#3A6090"/>
    <SolidColorBrush x:Key="QuickReplyText" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="QuickReplyHoverSurface" Color="#253550"/>
    <!-- Recording Tokens -->
    <SolidColorBrush x:Key="RecordingLevelFill" Color="#4090E0"/>
    <SolidColorBrush x:Key="RecordingIconFill" Color="#FF6060"/>
    <!-- ScrollBar Tokens -->
    <SolidColorBrush x:Key="ScrollBarTrackBrush" Color="#2A2520"/>
    <SolidColorBrush x:Key="ScrollBarThumbBrush" Color="#4A4438"/>
    <SolidColorBrush x:Key="ScrollBarThumbHoverBrush" Color="#6A6050"/>
    <SolidColorBrush x:Key="ScrollBarThumbPressedBrush" Color="#8A7A68"/>
    <!-- IntelliSense Popup Tokens -->
    <SolidColorBrush x:Key="IntelliSenseSelectedSurface" Color="#1A3050"/>
    <SolidColorBrush x:Key="IntelliSenseSelectedText" Color="#E5D5C0"/>
    <SolidColorBrush x:Key="IntelliSenseHoverSurface" Color="#353028"/>
    <!-- Effect Token -->
    <DropShadowEffect x:Key="PopupShadow" BlurRadius="10" Opacity="0.55" ShadowDepth="2" Color="#000000"/>
    <!-- Search Highlight Tokens -->
    <SolidColorBrush x:Key="SearchHighlight"            Color="#8E7735"/>
    <SolidColorBrush x:Key="SearchHighlightCurrent"     Color="#FFE57A"/>
    <SolidColorBrush x:Key="SearchHighlightText"        Color="#120D00"/>
    <SolidColorBrush x:Key="SearchHighlightTextCurrent" Color="#000000"/>
    <!-- Revision Highlight Token (used by RevisionHighlightAdorner while AI is revising) -->
    <SolidColorBrush x:Key="RevisionHighlight"          Color="#1A3A5C"/>
    <SolidColorBrush x:Key="RevisionHighlightText"      Color="#C8E6C9"/>
    <!-- Screenshot Overlay Tokens -->
    <SolidColorBrush x:Key="OverlayDimFill"             Color="#80000000"/>
    <SolidColorBrush x:Key="ScreenshotAnchorNamed"       Color="#4CAF50"/>
    <SolidColorBrush x:Key="ScreenshotAnchorUnnamed"     Color="#FFC107"/>
    <SolidColorBrush x:Key="ScreenshotAnchorMissing"     Color="#F44336"/>
    <!-- TreeView unfocused-selection override (prevents light-grey bleed in dark theme) -->
    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#2B4065"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#D8C8B0"/>
</ResourceDictionary>
