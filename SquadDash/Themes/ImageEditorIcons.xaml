<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Image Editor toolbar icon templates.
        Each resource is a Viewbox sized to 18×18 logical units.
        Replace the placeholder Path geometry with your own designs.
        These are referenced by key from ClipboardImageEditorWindow.cs.

        Keys:
          ImageEditorArrowIcon      — arrow/annotation tool
          ImageEditorRectIcon       — rectangle annotation tool
          ImageEditorCursorIcon     — mouse-cursor indicator tool
          ImageEditorEyedropperIcon — colour eyedropper tool
          ImageEditorRoundCornersIcon — round corners mask tool
    -->

    <!-- Arrow tool icon -->
    <Viewbox x:Key="ImageEditorArrowIcon" Width="18" Height="18" Stretch="Uniform">
        <Canvas Width="268" Height="289">
            <Canvas>
                <Canvas.Clip>
                    <RectangleGeometry Rect="20,30,219,240" />
                </Canvas.Clip>
                <Polygon Points="20.25,248.1875 155.125,113.375 134.625,92.9375 237.75,52 196.8125,155.125 176.375,134.625 41.5625,269.5" FillRule="EvenOdd" Fill="#4B000000" Stroke="{x:Null}" />
            </Canvas>
            <Polygon Points="23.4375,223.3125 155.125,91.625 134.625,71.1875 237.75,30.3125 196.8125,133.375 176.375,112.9375 44.75,244.625" FillRule="EvenOdd" Fill="{DynamicResource LabelText}" Stroke="{x:Null}" />
        </Canvas>
    </Viewbox>


