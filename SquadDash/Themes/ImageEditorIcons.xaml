    <!-- Crop tool icon — overlapping L-shaped corner brackets -->
    <Viewbox x:Key="ImageEditorCropIcon" Width="18" Height="18" Stretch="Uniform">
        <Canvas Width="100" Height="100">
            <!-- Top-left L bracket -->
            <Rectangle Canvas.Left="10" Canvas.Top="10" Width="8" Height="35" Fill="{DynamicResource LabelText}" RadiusX="2" RadiusY="2"/>
            <Rectangle Canvas.Left="10" Canvas.Top="10" Width="35" Height="8" Fill="{DynamicResource LabelText}" RadiusX="2" RadiusY="2"/>
            <!-- Bottom-right L bracket -->
            <Rectangle Canvas.Left="82" Canvas.Top="55" Width="8" Height="35" Fill="{DynamicResource LabelText}" RadiusX="2" RadiusY="2"/>
            <Rectangle Canvas.Left="55" Canvas.Top="82" Width="35" Height="8" Fill="{DynamicResource LabelText}" RadiusX="2" RadiusY="2"/>
            <!-- Diagonal crop line from TL to BR -->
            <Line X1="18" Y1="82" X2="82" Y2="18" Stroke="{DynamicResource LabelText}" StrokeThickness="5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
        </Canvas>
    </Viewbox>

    <!-- Round corners mask icon -->
    <Viewbox x:Key="ImageEditorRoundCornersIcon" Width="18" Height="18" Stretch="Uniform">
        <!-- Replace with your design -->
        <Canvas Width="18" Height="18">
            <Path Stroke="{DynamicResource LabelText}" StrokeThickness="1.5" Fill="Transparent"
                  Data="M 6,2 Q 2,2 2,6 L 2,12 Q 2,16 6,16 L 12,16 Q 16,16 16,12 L 16,6 Q 16,2 12,2 Z"/>
        </Canvas>
    </Viewbox>

</ResourceDictionary>
