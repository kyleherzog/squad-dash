<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Image Editor toolbar icon templates.
        Each resource is a Viewbox sized to 18×18 logical units.
        Replace the placeholder Path geometry with your own designs.
        These are referenced by key from ClipboardImageEditorWindow.cs.

        Keys:
          ImageEditorArrowIcon      — arrow/annotation tool
          ImageEditorRectIcon       — rectangle annotation tool
          ImageEditorCursorIcon     — mouse-cursor indicator tool
          ImageEditorEyedropperIcon — colour eyedropper tool
          ImageEditorRoundCornersIcon — round corners mask tool
    -->

    <!-- Arrow tool icon -->
    <Viewbox x:Key="ImageEditorArrowIcon" Width="18" Height="18" Stretch="Uniform">
        <!-- ↙ Replace the Path Data below with your design -->
        <Canvas Width="18" Height="18">
            <Path Fill="{DynamicResource LabelText}"
                  Data="M 14,2 L 2,14 L 5,11 L 2,14 L 5,14 L 5,11 M 14,2 L 14,8 M 14,2 L 8,2"/>
        </Canvas>
    </Viewbox>

    <!-- Rectangle annotation tool icon -->
    <Viewbox x:Key="ImageEditorRectIcon" Width="18" Height="18" Stretch="Uniform">
        <!-- Replace with your design -->
        <Canvas Width="18" Height="18">
            <Rectangle Canvas.Left="2" Canvas.Top="2" Width="14" Height="14"
                       Stroke="{DynamicResource LabelText}" StrokeThickness="1.5"
                       Fill="Transparent"/>
        </Canvas>
    </Viewbox>

    <!-- Cursor indicator tool icon -->
    <Viewbox x:Key="ImageEditorCursorIcon" Width="18" Height="18" Stretch="Uniform">
        <!-- Replace with your design -->
        <Canvas Width="18" Height="18">
            <Path Fill="{DynamicResource LabelText}"
                  Data="M 3,1 L 3,14 L 6,11 L 8,16 L 10,15 L 8,10 L 12,10 Z"/>
        </Canvas>
    </Viewbox>

    <!-- Eyedropper / colour picker icon -->
    <Viewbox x:Key="ImageEditorEyedropperIcon" Width="18" Height="18" Stretch="Uniform">
        <!-- Replace with your design -->
        <Canvas Width="18" Height="18">
            <Path Stroke="{DynamicResource LabelText}" StrokeThickness="1.5" Fill="Transparent"
                  Data="M 12,2 L 16,6 L 7,15 L 3,15 L 3,11 Z M 12,2 L 16,6"/>
            <Ellipse Canvas.Left="2" Canvas.Top="13" Width="4" Height="4"
                     Fill="{DynamicResource LabelText}"/>
        </Canvas>
    </Viewbox>

    <!-- Round corners mask icon -->
    <Viewbox x:Key="ImageEditorRoundCornersIcon" Width="18" Height="18" Stretch="Uniform">
        <!-- Replace with your design -->
        <Canvas Width="18" Height="18">
            <Path Stroke="{DynamicResource LabelText}" StrokeThickness="1.5" Fill="Transparent"
                  Data="M 6,2 Q 2,2 2,6 L 2,12 Q 2,16 6,16 L 12,16 Q 16,16 16,12 L 16,6 Q 16,2 12,2 Z"/>
        </Canvas>
    </Viewbox>

</ResourceDictionary>
