    <!-- Eyedropper / colour picker icon — classic pipette, tip at lower-left -->
    <Viewbox x:Key="ImageEditorEyedropperIcon" Width="18" Height="18" Stretch="Uniform">
        <Canvas Width="32" Height="32">
            <!-- Body: horizontal rounded-rect rotated -45°, giving a diagonal tube
                 with a natural rounded cap at upper-right and collar end at lower-left.
                 Center lands at ~(16,15.5); cap ~(23–28, 4–9); nozzle end ~(4–9, 22–27). -->
            <Rectangle Canvas.Left="3" Canvas.Top="12" Width="26" Height="7"
                       RadiusX="3.5" RadiusY="3.5"
                       Fill="{DynamicResource LabelText}"
                       RenderTransformOrigin="0.5,0.5">
                <Rectangle.RenderTransform>
                    <RotateTransform Angle="-45"/>
                </Rectangle.RenderTransform>
            </Rectangle>
            <!-- Nozzle: short connector from body end to tip -->
            <Line X1="7" Y1="25" X2="4" Y2="28"
                  Stroke="{DynamicResource LabelText}" StrokeThickness="2.5"
                  StrokeStartLineCap="Flat" StrokeEndLineCap="Round"/>
            <!-- Tip sample dot -->
            <Ellipse Canvas.Left="1.5" Canvas.Top="25.5" Width="5" Height="5"
                     Fill="{DynamicResource LabelText}"/>
        </Canvas>
    </Viewbox>

    <!-- Text annotation tool icon — bold "T" letterform -->
    <Viewbox x:Key="ImageEditorTextIcon" Width="18" Height="18" Stretch="Uniform">
        <Canvas Width="100" Height="100">
            <!-- Horizontal crossbar -->
            <Rectangle Canvas.Left="8" Canvas.Top="10" Width="84" Height="14"
                       Fill="{DynamicResource LabelText}" RadiusX="3" RadiusY="3"/>
            <!-- Vertical stem -->
            <Rectangle Canvas.Left="43" Canvas.Top="10" Width="14" Height="78"
                       Fill="{DynamicResource LabelText}" RadiusX="3" RadiusY="3"/>
        </Canvas>
    </Viewbox>

