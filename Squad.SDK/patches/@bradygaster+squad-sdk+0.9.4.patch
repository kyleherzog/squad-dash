+        return this.storage;
+    }
+    /**
+     * Factory method — validates that `rootDir/.squad/` exists before
+     * returning a new SquadState instance.
+     */
+    static async create(storage, rootDir) {
+        const squadDir = `${rootDir}/.squad`;
+        const exists = await storage.exists(squadDir);
+        if (!exists) {
