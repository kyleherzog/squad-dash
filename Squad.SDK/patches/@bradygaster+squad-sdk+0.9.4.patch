+export class SquadState {
+    storage;
+    _rootDir;
+    agents;
+    config;
+    decisions;
+    routing;
+    team;
+    skills;
+    templates;
+    log;
+    constructor(storage, _rootDir) {
+        this.storage = storage;
+        this._rootDir = _rootDir;
